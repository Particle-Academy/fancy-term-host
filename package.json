{
  "name": "@particle-academy/fancy-term-host",
  "version": "0.2.2",
  "description": "Headless Node terminal backend for @particle-academy/fancy-term — owns the PTYs (node-pty) and the T1/T2/T3 persistence engine (snapshot+replay, retained PTYs, detached pty-host) behind four injected ports. OS-agnostic, zero hard third-party deps.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-term-host.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-term-host#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-term-host/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./pty-host": {
      "import": "./dist/pty-host.js",
      "require": "./dist/pty-host.cjs"
    },
    "./service": {
      "import": {
        "types": "./dist/service.d.ts",
        "default": "./dist/service.js"
      },
      "require": {
        "types": "./dist/service.d.cts",
        "default": "./dist/service.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "terminal",
    "pty",
    "node-pty",
    "xterm",
    "shell",
    "fancy",
    "fancy-term",
    "human-plus",
    "osc7",
    "agent"
  ],
  "peerDependencies": {
    "node-pty": "^1.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "node-pty": "^1.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
